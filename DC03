#DC3import random

servers = ["Server1", "Server2", "Server3"]

# Round Robin
class RoundRobin:
    def __init__(self):
        self.i = 0

    def get_server(self):
        server = servers[self.i]
        self.i = (self.i + 1) % len(servers)
        return server


# Random Load Balancer
class RandomLB:
    def get_server(self):
        return random.choice(servers)


# Simulate Requests
def simulate(lb, n):
    for i in range(1, n + 1):
        print(f"Request {i} -> {lb.get_server()}")


print("Round Robin")
simulate(RoundRobin(), 10)

print("\nRandom Load Balancing")
simulate(RandomLB(), 10)
